# ---- Firebase client config (safe to expose in the browser bundle) ----
# Get these exact values from:
# Firebase Console > Project settings > General > Your apps >
# ai-studio-applet-webapp > SDK setup and configuration > Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=hirenest-os.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hirenest-os
VITE_FIREBASE_STORAGE_BUCKET=hirenest-os.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=733294346096
VITE_FIREBASE_APP_ID=1:733294346096:web:aff62b8af002186e7e99b5

# Named Firestore database (NOT the default database)
VITE_FIREBASE_DATABASE_ID=hirenestwebsiteleads

# Where form-submission notification emails should be sent
VITE_NOTIFICATION_EMAIL=gopal@hirenestworkforce.com

# ---- EmailJS (free, no credit card) — actually sends the notification emails ----
# Sign up free at https://www.emailjs.com, connect your inbox as a Service,
# create a Template, then fill these in from your EmailJS dashboard:
VITE_EMAILJS_SERVICE_ID= service_4z3j0zw
VITE_EMAILJS_TEMPLATE_ID= template_buwzsnm
VITE_EMAILJS_PUBLIC_KEY= IBhzpEIsF2y3C2lOx

# ---- Server-side only (used by /api/*.js on Vercel — DO NOT prefix with VITE_) ----
# Option A: paste the whole downloaded service-account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: or split into three vars instead of the JSON above
FIREBASE_PROJECT_ID=hirenest-os
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

FIREBASE_DATABASE_ID=hirenestwebsiteleads
NOTIFICATION_EMAIL=gopal@hirenestworkforce.com
